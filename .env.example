# Sasan Perfumes - Environment Variables
# Copy this file to .env.local and fill in the values

# ===========================================
# WordPress/WooCommerce Backend Configuration
# ===========================================

# WordPress GraphQL endpoint URL
NEXT_PUBLIC_WORDPRESS_GRAPHQL_URL=https://cms.sasanperfumes.com/graphql

# Site URL (your frontend URL — Vercel deployment or custom domain)
NEXT_PUBLIC_SITE_URL=https://store.sasanperfumes.com

# WordPress API endpoint host
# Use https://cms.sasanperfumes.com for all environments.
NEXT_PUBLIC_WC_API_URL=https://cms.sasanperfumes.com

# Optional: override canonical host for redirect behavior.
NEXT_PUBLIC_CANONICAL_HOST=store.sasanperfumes.com
# Optional: allow multiple canonical hosts (comma-separated), useful for staging + production.
# Example: NEXT_PUBLIC_CANONICAL_HOSTS=store.sasanperfumes.com
NEXT_PUBLIC_CANONICAL_HOSTS=store.sasanperfumes.com

# Optional: set true for staging builds that should not appear in search results.
NEXT_PUBLIC_DISABLE_INDEXING=false

# Optional: allow-listed host aliases for middleware host handling.
NEXT_PUBLIC_ALLOWED_HOSTS=localhost,127.0.0.1,::1,store.sasanperfumes.com,cms.sasanperfumes.com,localhost:3000,localhost:3001

# Optional: extra WordPress media hosts for next/image optimization.
NEXT_PUBLIC_CMS_IMAGE_HOSTS=cms.sasanperfumes.com

# Optional Sasan Perfumes brand assets
# Leave empty to show the text logo in the copied frontend.
NEXT_PUBLIC_BRAND_LOGO_URL=
NEXT_PUBLIC_BRAND_FAVICON_URL=
NEXT_PUBLIC_USE_BACKEND_BRAND_ASSETS=false

# ===========================================
# WooCommerce REST API Credentials
# Required for wishlist functionality (TI WooCommerce Wishlist plugin)
# ===========================================

# WooCommerce Consumer Key (from WooCommerce > Settings > Advanced > REST API)
# Create a key with Read/Write permissions
WC_CONSUMER_KEY=ck_your_consumer_key_here

# WooCommerce Consumer Secret
WC_CONSUMER_SECRET=cs_your_consumer_secret_here

# Optional per-market WooCommerce REST keys.
# Create each key inside that market's WordPress admin with Read/Write permissions.
WC_CONSUMER_KEY_QA=ck_your_qatar_consumer_key_here
WC_CONSUMER_SECRET_QA=cs_your_qatar_consumer_secret_here
WC_CONSUMER_KEY_OM=ck_your_oman_consumer_key_here
WC_CONSUMER_SECRET_OM=cs_your_oman_consumer_secret_here
WC_CONSUMER_KEY_SA=ck_your_saudi_consumer_key_here
WC_CONSUMER_SECRET_SA=cs_your_saudi_consumer_secret_here

# ===========================================
# Google Sign-In Configuration
# ===========================================

# Google OAuth Client ID (from Google Cloud Console)
# Required for Google Sign-In button on login/register pages
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# Secret key for deriving social login passwords (optional)
# Falls back to WC_CONSUMER_SECRET if not set
# SOCIAL_LOGIN_SECRET=your_random_secret_here

# ===========================================
# Payment Gateway Configuration
# ===========================================

# Stripe / WooPayments card gateway
STRIPE_SECRET_KEY=your_stripe_secret_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Tabby Payment Gateway (Buy Now Pay Later)
# Get your credentials from Tabby merchant portal
TABBY_SECRET_KEY=your_tabby_secret_key_here
TABBY_MERCHANT_CODE=your_tabby_merchant_code_here

# Optional Hostinger JSON overrides for enabled payment methods and ordering.
# Example:
# PAYMENT_GATEWAYS_JSON=[{"id":"cod","title":"Cash on Delivery","description":"Pay on delivery","order":0,"enabled":true}]
PAYMENT_GATEWAYS_JSON=

# Optional per-market allow/block lists for payment gateway IDs.
# These IDs must match WooCommerce gateway IDs returned from /wc/v3/payment_gateways.
# If an allowlist is set, only listed IDs are shown. Blocklist removes IDs even if allowed/active.
# You can set market-specific values using suffixes _QA / _OM / _SA.
# PAYMENT_GATEWAYS_ALLOWLIST=woocommerce_payments,stripe
# PAYMENT_GATEWAYS_BLOCKLIST=cod,bacs,cheque
# PAYMENT_GATEWAYS_ALLOWLIST_QA=woocommerce_payments
# PAYMENT_GATEWAYS_BLOCKLIST_QA=cod,bacs,cheque
# PAYMENT_GATEWAYS_ALLOWLIST_OM=woocommerce_payments
# PAYMENT_GATEWAYS_BLOCKLIST_OM=cod,bacs,cheque
# PAYMENT_GATEWAYS_ALLOWLIST_SA=woocommerce_payments
# PAYMENT_GATEWAYS_BLOCKLIST_SA=cod,bacs,cheque
PAYMENT_GATEWAYS_ALLOWLIST=
PAYMENT_GATEWAYS_BLOCKLIST=
PAYMENT_GATEWAYS_ALLOWLIST_QA=
PAYMENT_GATEWAYS_BLOCKLIST_QA=
PAYMENT_GATEWAYS_ALLOWLIST_OM=
PAYMENT_GATEWAYS_BLOCKLIST_OM=
PAYMENT_GATEWAYS_ALLOWLIST_SA=
PAYMENT_GATEWAYS_BLOCKLIST_SA=

# Optional Hostinger JSON override for the Aramex freight table used by shipping.
# Example:
# SHIPPING_FREIGHT_TABLE_JSON=[{"weight":"0.5KG","pcs":1,"saudi_arabia":100,"bahrain":91,"kuwait":107,"qatar":99}]
SHIPPING_FREIGHT_TABLE_JSON=

# ===========================================
# Analytics & Tracking
# ===========================================

# Google Ads Conversion ID (for Google Ads remarketing/conversion tracking)
NEXT_PUBLIC_GOOGLE_ADS_ID=

# Pinterest Domain Verification
NEXT_PUBLIC_PINTEREST_DOMAIN_VERIFY=

# Omnisend Email Marketing
# Brand ID from Omnisend Settings (used for abandoned cart tracking)
# Get from: https://app.omnisend.com/ > Settings > Your Brand ID
NEXT_PUBLIC_OMNISEND_BRAND_ID=your_omnisend_brand_id_here

# Omnisend API Key (server-side only, used for REST API cart sync)
# Required for abandoned cart automation workflow to trigger correctly.
# Get from: https://app.omnisend.com/ > Store Settings > API Keys
OMNISEND_API_KEY=your_omnisend_api_key_here

# Tamara Payment Gateway (Buy Now Pay Later)
# Get your credentials from Tamara merchant portal
TAMARA_API_TOKEN=your_tamara_api_token_here
# Public key for Tamara promo widgets (required for widget display)
NEXT_PUBLIC_TAMARA_PUBLIC_KEY=your_tamara_public_key_here
# Country code for Tamara widget (SA for Saudi Arabia, AE for UAE)
# This is required for the Tamara widget to load correctly
NEXT_PUBLIC_TAMARA_COUNTRY=AE
